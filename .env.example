# Example environment configuration for MT5 Candle Service

# MetaTrader 5 Account Configuration
MT5_ACCOUNT_NUMBER=12345678
MT5_ACCOUNT_PASSWORD=your_password_here
MT5_ACCOUNT_SERVER=your-broker-server.com

# Path to MetaTrader 5 terminal executable
# Windows example:
PATH_MT5_EXEC=C:\Program Files\MetaTrader 5\terminal64.exe

# Broker UTC offset in hours
# For example:
#   EET (Eastern European Time, +2 UTC) = 2
#   CET (Central European Time, +1 UTC) = 1
#   UTC+0 = 0
# Note: This is auto-verified every 6 hours to detect DST changes
BROKER_UTC_OFFSET_HOURS=2

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
